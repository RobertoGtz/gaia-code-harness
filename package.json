{
  "name": "gaia-code-harness",
  "version": "1.0.0",
  "description": "Gaia Code Harness - Controlled AI code generation with human oversight",
  "main": "dist/index.js",
  "scripts": {
    "dev": "ts-node src/index.ts",
    "build": "tsc",
    "start": "node dist/index.js",
    "gaia": "ts-node src/cli/run.ts",
    "db:init": "ts-node -e \"require('./src/db').initDatabase().then(() => process.exit(0))\"",
    "test": "jest",
    "test:watch": "jest --watch",
    "lint": "eslint src/**/*.ts",
    "clean": "rm -rf dist"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.27.0",
    "@fastify/cors": "^9.0.0",
    "@modelcontextprotocol/sdk": "^0.5.0",
    "axios": "^1.6.0",
    "dotenv": "^17.4.2",
    "fastify": "^4.26.0",
    "minimatch": "^9.0.0",
    "openai": "^6.42.0",
    "pg": "^8.11.0",
    "simple-git": "^3.22.0",
    "uuid": "^9.0.0",
    "zod": "^3.22.0"
  },
  "devDependencies": {
    "@jest/core": "^29.7.0",
    "@types/jest": "^29.5.0",
    "@types/node": "^20.10.0",
    "@types/pg": "^8.10.0",
    "@typescript-eslint/eslint-plugin": "^6.0.0",
    "@typescript-eslint/parser": "^6.0.0",
    "eslint": "^8.0.0",
    "jest": "^29.7.0",
    "jest-cli": "^29.7.0",
    "jest-util": "^29.7.0",
    "ts-jest": "^29.0.0",
    "ts-node": "^10.9.0",
    "typescript": "^5.3.0"
  },
  "keywords": [
    "ai",
    "code-generation",
    "flutter",
    "harness-engineering",
    "spec-driven-development"
