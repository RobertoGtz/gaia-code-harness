# Gaia Code Harness - Environment Configuration

# Server
PORT=3000

# Database (PostgreSQL)
DATABASE_URL=postgresql://user:pass@localhost:5432/gaia_harness

# GitHub (for creating PRs)
# Get token from: https://github.com/settings/tokens (needs 'repo' scope)
GITHUB_TOKEN=ghp_your_github_personal_access_token
GITHUB_OWNER=rappi  # GitHub organization or user

# Jira (for reading tickets, adding comments, and transitioning states)
# Get API token from: https://id.atlassian.com/manage-profile/security/api-tokens
JIRA_BASE_URL=https://rappi.atlassian.net
JIRA_EMAIL=your.email@rappi.com
JIRA_API_TOKEN=your_jira_api_token
# Override Jira transition names (JSON). Defaults shown — adjust to your workflow:
# JIRA_TRANSITION_MAP={"implementing":"In Progress","done":"Done","failed":"Blocked"}

# LLM Providers (for code generation)
# Get from: https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-your_openai_key

# Get from: https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=sk-ant-your_anthropic_key

# Workspace Paths
# Where repos will be cloned/worked on
REPOS_BASE_PATH=/tmp/gaia-workspace

# Optional: Path to local repos for development
# If set, will use local copy instead of cloning
LOCAL_REPOS_PATH=/Users/robertogutierrezgonzalez/Desktop/repos

# MCP Configuration
# Path to MCP settings JSON file (optional)
MCP_SETTINGS_PATH=/Users/robertogutierrezgonzalez/.codeium/windsurf/mcp_config.json

# ── CI / Webhook mode ─────────────────────────────────────────────────────────

# Inbound webhook security (HMAC-SHA256 — same scheme used for outbound events)
# Set this to reject unsigned payloads on POST /webhook/trigger
WEBHOOK_SECRET=your_webhook_secret

# Default repo used when the inbound payload does not include one (Jira webhooks)
DEFAULT_REPO=your-org/your-repo

# Outbound notifications — enable one or more:

# Slack incoming webhook URL
# Create at: https://api.slack.com/messaging/webhooks
SLACK_WEBHOOK_URL=https://hooks.slack.com/services/T000/B000/xxxx

# GitHub Checks API (fine-grained PAT with checks:write + repo scope)
# https://github.com/settings/tokens?type=beta
GITHUB_CHECKS_TOKEN=github_pat_your_token
GITHUB_REPO=your-repo-name   # GITHUB_OWNER already set above

# Generic outbound webhook (any HTTP endpoint)
NOTIFY_WEBHOOK_URL=https://your-endpoint.example.com/gaia-events
NOTIFY_WEBHOOK_SECRET=your_outbound_secret   # optional HMAC signing
